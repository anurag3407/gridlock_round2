# When this is set to 1 the UI uses /mocks/*.json bundled with the build.
# Unset (or set to 0) and ML_API_URL to point at the live FastAPI backend.
NEXT_PUBLIC_USE_MOCK=1

# Set this when the FastAPI backend is up (Person A's service).
# Server-only — kept off the client.
# ML_API_URL=http://localhost:8000

# Mappls (MapmyIndia) keys for the production map.
# NEXT_PUBLIC_MAPPLS_KEY=your-public-key
# MAPPLS_REST_KEY=your-rest-key
